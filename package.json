{
  "name": "sanctuario-cemetery-management",
  "version": "1.0.0",
  "description": "Cemetery Management System for Sanctuario de Santa Rosa de Lima Memorial Park",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "client": "cd client && npm start",
    "build": "cd client && npm run build",
    "install-client": "cd client && npm install",
    "seed": "node scripts/seedData.js",
    "setup": "npm install && cd client && npm install && cd .. && npm run seed",
    "full-start": "concurrently \"npm run dev\" \"npm run client\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "validator": "^13.11.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  },
  "keywords": [
    "cemetery",
    "management",
    "digital-mapping",
    "memorial-park",
    "react",
    "nodejs",
    "mongodb"
  ],
  "author": "Cemetery Management System",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0"
  }
}
